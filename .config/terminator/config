[global_config]
  window_state = hidden
  tab_position = bottom
  suppress_multiple_term_dialog = True
  title_use_system_font = False
  title_font = JetBrains Mono NL Semi-Bold 12
[keybindings]
  split_horiz = <Alt>underscore
  split_vert = <Alt>plus
  resize_up = <Shift><Alt>Up
  resize_down = <Shift><Alt>Down
  resize_left = <Shift><Alt>Left
  resize_right = <Shift><Alt>Right
[profiles]
  [[default]]
    icon_bell = False
    background_darkness = 0.9
    background_type = transparent
    cursor_color = "#aaaaaa"
    font = JetBrains Mono Semi-Bold 12
    show_titlebar = False
    scrollbar_position = hidden
    scrollback_lines = 1000
    use_system_font = False
    use_theme_colors = True
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
[plugins]
