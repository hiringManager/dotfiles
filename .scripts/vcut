#!/bin/bash

# Some delimiters in the file name were fucking up here recently I think. Was it .m4a causing a problem or something? May need to comment out -codec copy

# Depends
# python3 -m pip install -U yt-dlp ; sudo apt install ffmpeg

FILE="$1"
START="$2"
END="$3"
TMP="/tmp/vcut"
OUT="~/output"

mkdir $TMP
mkdir $OUT
cd $TMP

# Changing format to webm. Remove -codec copy if this shit breaks
yt-dlp $FILE
ffmpeg -ss $START -to $END -i ./* -codec copy output$RANDOM.webm

mv $TMP/* ~/output
mv -n ~/output/out* ~/Downloads/

