# Iterate over files in the current directory
for file in *; do
    # Check if the file is a regular file
    if [ -f "$file" ]; then
        # Generate a random combination of adjective, verb, and noun
        random_adjective=${adjectives[$RANDOM % ${#adjectives[@]} ]}
        random_verb=${verbs[$RANDOM % ${#verbs[@]} ]}
        random_noun=${nouns[$RANDOM % ${#nouns[@]} ]}

        # Remove underscores from the adjective, verb, and noun
        random_adjective=${random_adjective//_/}
        random_verb=${random_verb//_/}
        random_noun=${random_noun//_/}

        # Convert the adjective, verb, and noun to lowercase
        #random_adjective=$(echo "$random_adjective" | tr '[:upper:]' '[:lower:]')
        #random_verb=$(echo "$random_verb" | tr '[:upper:]' '[:lower:]')
        #random_noun=$(echo "$random_noun" | tr '[:upper:]' '[:lower:]')

        # Get the file extension
        extension="${file##*.}"

        # Construct the new filename
        new_filename="${random_adjective}${random_verb}${random_noun}.${extension}"

        # Rename the file
        mv "$file" "$new_filename"

        echo "File renamed: $file -> $new_filename"
    fi
done
